---
import LayoutBlog from "../../../layouts/LayoutBlog.astro";
import BackToBlog from "../../../components/ui/BackToBlog.astro";
import "../../../styles/global.css";

const plantillas = [
  {
    title: "Tienda Florerías",
    description:
      "E-commerce para florerías con dashboard administrativo, tienda en línea y pedidos redirigidos directamente a WhatsApp.",
    repo: "https://github.com/Hugo-DevM/Tienda-Florerias",
    zip: "https://github.com/Hugo-DevM/Tienda-Florerias/archive/refs/heads/main.zip",
  },
  {
    title: "Boutique",
    description:
      "E-commerce básico para boutiques y tiendas de ropa, con dashboard para subir productos por tipo de prenda y pedidos por WhatsApp.",
    repo: "https://github.com/Hugo-DevM/Boutique",
    zip: "https://github.com/Hugo-DevM/Boutique/archive/refs/heads/main.zip",
  },
];
---

<LayoutBlog
  title="Plantillas"
  description="Plantillas gratuitas para páginas web, landing pages y e-commerce. Descárgalas y úsalas en tus proyectos."
>
  <BackToBlog />
  <main class="main-plantillas">
    <h1 class="title-plantillas">
      Plantillas <span class="highlight">gratuitas</span> para tus proyectos
    </h1>
    <p class="subtitle-plantillas">
      Descárgalas, personalízalas y úsalas en lo que necesites.
    </p>

    <div class="plantillas-grid">
      {
        plantillas.map((p) => (
          <article class="plantilla-card">
            <h2 class="plantilla-title">{p.title}</h2>
            <p class="plantilla-description">{p.description}</p>
            <div class="plantilla-actions">
              <a class="download-btn" href={p.zip} rel="noopener">
                Descargar ZIP
              </a>
              <a class="repo-link" href={p.repo} target="_blank" rel="noopener">
                Ver en GitHub
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</LayoutBlog>

<style>
  .main-plantillas {
    flex: 1;
    display: flex;
    align-items: center;
    flex-direction: column;
    padding: 3rem 2rem 5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  .title-plantillas {
    font-size: 3rem;
    text-align: center;
    color: #fafafa;
    margin-bottom: 0;
    line-height: 1.3;
  }

  .highlight {
    background-image: var(--color-gradient);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .subtitle-plantillas {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1.1rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .plantillas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 420px));
    justify-content: center;
    gap: 2rem;
    width: 100%;
  }

  .plantilla-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    background: var(--color-card);
    border: 1px solid rgba(159, 32, 239, 0.15);
    border-radius: 1rem;
    padding: 2rem;
    transition: all 0.4s ease;
  }

  .plantilla-card:hover {
    transform: translateY(-6px);
    border-color: rgba(159, 32, 239, 0.4);
  }

  .plantilla-title {
    color: white;
    font-size: 1.4rem;
    margin: 0;
  }

  .plantilla-description {
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  .plantilla-actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 0.5rem;
  }

  .download-btn {
    display: inline-block;
    background: var(--color-gradient);
    color: white;
    text-decoration: none;
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    border-radius: 12px;
    transition: all 0.4s ease;
  }

  .download-btn:hover {
    scale: 1.08;
  }

  .repo-link {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
    transition: filter 0.3s ease;
  }

  .repo-link:hover {
    filter: brightness(1.3);
  }

  @media (max-width: 768px) {
    .title-plantillas {
      font-size: 2rem;
    }
  }
</style>
