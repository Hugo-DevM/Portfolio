---
import { getCollection, render } from "astro:content";
import LayoutBlog from "../../../layouts/LayoutBlog.astro";
import BackToBlog from "../../../components/ui/BackToBlog.astro";
import "../../../styles/global.css";

export async function getStaticPaths() {
  const articulos = await getCollection("articulos", ({ data }) => !data.draft);
  return articulos.map((articulo) => ({
    params: { slug: articulo.id },
    props: { articulo },
  }));
}

const { articulo } = Astro.props;
const { Content } = await render(articulo);

const fecha = articulo.data.date.toLocaleDateString("es-MX", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<LayoutBlog
  title={articulo.data.title}
  description={articulo.data.description}
  type="article"
  publishedTime={articulo.data.date.toISOString()}
  tags={articulo.data.tags}
>
  <BackToBlog />
  <main class="main-articulo">
    <article>
      <header class="articulo-header">
        <h1 class="articulo-title">{articulo.data.title}</h1>
        <div class="articulo-meta">
          <time datetime={articulo.data.date.toISOString()}>{fecha}</time>
          {
            articulo.data.tags.length > 0 && (
              <div class="articulo-tags">
                {articulo.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )
          }
        </div>
      </header>

      <div class="articulo-content">
        <Content />
      </div>
    </article>
  </main>
</LayoutBlog>

<style>
  .main-articulo {
    flex: 1;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    box-sizing: border-box;
  }

  article {
    background: rgba(11, 9, 19, 0.92);
    border: 1px solid rgba(159, 32, 239, 0.15);
    border-radius: 1rem;
    padding: 3rem;
  }

  .articulo-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(159, 32, 239, 0.25);
    padding-bottom: 2rem;
  }

  .articulo-title {
    color: #fafafa;
    font-size: 2.6rem;
    line-height: 1.25;
    margin: 0 0 1rem;
  }

  .articulo-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .articulo-meta time {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.95rem;
  }

  .articulo-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--color-primary);
    border: 1px solid rgba(159, 32, 239, 0.35);
    border-radius: 1000px;
    padding: 0.15rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Contenido del markdown (:global porque lo genera <Content />) */
  .articulo-content {
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .articulo-content :global(h2) {
    color: #fafafa;
    font-size: 1.7rem;
    margin: 2.5rem 0 1rem;
  }

  .articulo-content :global(h3) {
    color: #fafafa;
    font-size: 1.3rem;
    margin: 2rem 0 0.8rem;
  }

  .articulo-content :global(a) {
    color: var(--color-primary);
    font-weight: 600;
  }

  .articulo-content :global(strong) {
    color: white;
  }

  .articulo-content :global(code) {
    background: rgba(159, 32, 239, 0.12);
    border: 1px solid rgba(159, 32, 239, 0.2);
    border-radius: 6px;
    padding: 0.1rem 0.4rem;
    font-size: 0.9em;
  }

  .articulo-content :global(pre) {
    border: 1px solid rgba(159, 32, 239, 0.2);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    overflow-x: auto;
  }

  .articulo-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .articulo-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    margin: 1.5rem 0;
    padding: 0.2rem 0 0.2rem 1.2rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .articulo-content :global(img) {
    max-width: 100%;
    border-radius: 12px;
  }

  @media (max-width: 768px) {
    .articulo-title {
      font-size: 1.9rem;
    }

    article {
      padding: 1.8rem 1.4rem;
    }
  }
</style>
