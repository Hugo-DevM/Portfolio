---
import "./card.css";
const {
  webLink,
  img,
  title,
  description,
  project,
  skills = [],
  status,
  logo = false,
  logoBg,
} = Astro.props;
---

<div class="card">
  <div
    class:list={["content-img-projects", { "img-logo": logo }]}
    style={logoBg ? `background: ${logoBg}` : undefined}
  >
    {status && <span class="status-badge">{status}</span>}
    <img class="img" src={img} alt={`Captura de ${title}`} />
  </div>
  <div class="card-content">
    <a class="titleCard" href={webLink} target="_blank" rel="noopener"
      >{title}</a
    >
    <p class="description">{description}</p>
    <div class="content-skills">
      {skills.map((s: string) => <span class="pill">{s}</span>)}
    </div>
  </div>
</div>
