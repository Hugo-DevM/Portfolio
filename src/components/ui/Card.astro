---
import "./card.css";
const {
  webLink,
  img,
  title,
  description,
  project,
  linkProject,
  skills = [],
  status,
} = Astro.props;
---

<div class="card">
  <div class="content-img-projects">
    {status && <span class="status-badge">{status}</span>}
    <img class="img" src={img} alt={`Captura de ${title}`} />
  </div>
  <div class="card-content">
    <a class="titleCard" href={webLink}>{title}</a>
    <p class="description">{description}</p>
    <div class="content-skills">
      {skills.map((s: string) => <span class="pill">{s}</span>)}
    </div>
    <a class="github-link" href={linkProject} target="_blank">{project} →</a>
  </div>
</div>
