---
import "./styles/projects.css";

const featured = {
  img: "/fidelizasaas.webp",
  title: "Fideliza",
  webLink: "https://fideliza.app/",
  description:
    "Plataforma enfocada en la fidelización y retencion de clientes para negocios. Crea recompensas y premia a tus clientes mas fieles. (En desarrollo)",
  skills: ["Next.js", "React", "Tailwind", "TypeScript"],
};
---

<section class="projects" id="projects">
  <p class="section-eyebrow">01 · PRODUCTO SaaS</p>
  <h2 class="title-Proj">Producto SaaS</h2>
  <div class="featured-card">
    <a class="featured-img" href={featured.webLink} target="_blank">
      <img src={featured.img} alt={`Captura de ${featured.title}`} />
    </a>
    <div class="featured-content">
      <span class="featured-badge">⭐ PRINCIPAL</span>
      <a class="featured-title" href={featured.webLink} target="_blank"
        >{featured.title}</a
      >
      <p class="featured-description">{featured.description}</p>
      <div class="featured-skills">
        {featured.skills.map((s) => <span class="pill">{s}</span>)}
      </div>
    </div>
  </div>
</section>
