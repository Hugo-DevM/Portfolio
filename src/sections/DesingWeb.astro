---
import Card from "../components/ui/Card.astro";
import "./styles/projects.css";

const desingWeb = [
  {
    img: "/bravo.webp",
    webLink: "https://landing-page-bravvo.vercel.app/",
    title: "Bravvo Consulting",
    description:
      "Landing conceptual para consultoría de pymes enfocada en transmitir confianza y claridad en sus servicios.",
    skills: ["Astro", "HTML", "CSS", "JavaScript"],
  },
  {
    img: "/fidelizasaas.webp",
    logo: true,
    title: "Landing Fideliza",
    webLink: "https://www.fideliza.app/",
    description:
      "Landing page para Fideliza, el sistema de fidelización para negocios mas eficiente en todo México. (En desarrollo)",
    skills: ["Next.js", "HTML", "Tailwind", "TypeScript"],
  },
  {
    img: "/laptopsmaster.webp",
    logo: true,
    title: "Laptops Master",
    webLink: "https://www.laptopsmaster.com/",
    description:
      "Rediseño web para un negocio especializado en reparación y mantenimiento de equipos de cómputo, enfocado en mostrar servicios y mejorar la atención al cliente",
    skills: ["Astro", "HTML", "CSS", "JavaScript"],
  },
  {
    img: "/floreriatulipan.webp",
    logo: true,
    logoBg: "#fbfaf8",
    title: "Floreria Tulipan",
    webLink: "https://www.floreriatulipan.mx/",
    description:
      "E-commerce básico para una florería local con catálogo de productos, panel administrativo y pedidos automáticos por WhatsApp.",
    skills: ["Next.js", "HTML", "Tailwind", "TypeScript"],
  },
  {
    img: "/hamcsoft.webp",
    logo: true,
    title: "HAMCSoft",
    webLink: "https://hamcsoft.com/",
    description:
      "Sitio web corporativo de HAMCSoft, mi agencia de desarrollo web, creado para presentar servicios, proyectos y soluciones digitales para negocios y emprendedores.",
    skills: ["Next.js", "HTML", "Tailwind", "TypeScript"],
  },
  {
    img: "/globalsolutions.webp",
    title: "Global Solutions",
    webLink: "https://web-global-solutions.vercel.app/",
    description:
      "Landing page de gestion financiera para empresas en Puerto Vallarta y Bahía de Banderas.",
    skills: ["Astro", "HTML", "CSS", "JavaScript"],
  },
];
---

<section class="projects" id="clientes">
  <p class="section-eyebrow">02 · PARA CLIENTES</p>
  <h2 class="title-Proj">Proyectos para clientes</h2>
  <div class="content-cards">
    {
      desingWeb.map((p) => (
        <Card
          webLink={p.webLink}
          img={p.img}
          logo={p.logo}
          logoBg={p.logoBg}
          title={p.title}
          description={p.description}
          skills={p.skills}
        />
      ))
    }
  </div>
</section>
